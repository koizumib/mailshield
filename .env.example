# MailShield OSS — 環境変数設定例
# =============================================================================
#
#   このファイルをコピーして .env を作成してください。
#
#     cp .env.example .env
#
#   設定は2種類あります:
#
#   ① 環境変数（このファイル）— DB/MinIO/RabbitMQ 等のインフラ接続情報・シークレット
#   ② YAML 設定ファイル（config/*.yaml）— ルーティング・ポリシー・ワーカー等のロジック設定
#
#   本番運用前に YAML ファイルも必ず編集してください（後述）。
#
# =============================================================================


# =============================================================================
# ▼▼▼ 必ず変更が必要な項目 ▼▼▼
# =============================================================================

# ─── MTA ドメイン設定（mta profile 使用時のみ）────────────────────────────
# 受信するメールドメイン（カンマ区切りで複数指定可）
# MX レコードがこのサーバを指しているドメインを列挙する
MAILSHIELD_RELAY_DOMAINS=example.com

# このMTAのホスト名（MXレコードの値と合わせること）
MAILSHIELD_MTA_HOSTNAME=mail.example.com

# ─── MariaDB パスワード ─────────────────────────────────────────────────────
# MariaDB コンテナの root パスワード（infra profile 使用時のみ）
MARIADB_ROOT_PASSWORD=CHANGE_ME_root_password

# アプリケーション用 DB パスワード
DB_PASSWORD=CHANGE_ME_db_password

# ─── MinIO / S3 認証情報 ──────────────────────────────────────────────────
# MinIO をそのまま使う場合: 任意の文字列（8文字以上）
# 外部 S3 を使う場合: AWS アクセスキー / シークレットキー
MINIO_ACCESS_KEY=CHANGE_ME_minio_access_key
MINIO_SECRET_KEY=CHANGE_ME_minio_secret_key

# ─── RabbitMQ パスワード ────────────────────────────────────────────────────
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password

# ─── 通知メール SMTP パスワード（メール送信を有効にする場合）─────────────────
# api-server が隔離通知・OTP・添付ファイル通知を送るための SMTP 認証パスワード
# SMTP を使わない場合（再インジェクトのみ）は空のままでよい
NOTIFICATION_AUTH_PASS=

# ─── OIDC クライアントシークレット（OIDC 認証を有効にする場合）──────────────
# config/api-server.yaml の auth.providers.oidc.enabled: true にした場合のみ必要
OIDC_CLIENT_SECRET=


# =============================================================================
# ▼▼▼ 通常は変更不要（同梱インフラをそのまま使う場合のデフォルト値）▼▼▼
# =============================================================================

# ─── MariaDB 接続先 ──────────────────────────────────────────────────────────
# 同梱 MariaDB（infra profile）を使う場合はデフォルトのまま
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=mailshield
DB_USER=mailshield

# ─── MinIO (S3 互換) ─────────────────────────────────────────────────────────
# 同梱 MinIO（infra profile）を使う場合はデフォルトのまま
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# ─── RabbitMQ 接続先 ─────────────────────────────────────────────────────────
# 同梱 RabbitMQ（infra profile）を使う場合はデフォルトのまま
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=mailshield

# ─── Redis 接続先 ────────────────────────────────────────────────────────────
# 同梱 Redis（infra profile）を使う場合はデフォルトのまま
# Redis はセッション管理に使用（api profile / api-server サービスのみ）
REDIS_HOST=redis
REDIS_PORT=6379


# =============================================================================
# ▼▼▼ 外部サービスへの切り替え（必要な場合のみコメントを外す）▼▼▼
# =============================================================================

# ─── 外部 MariaDB / MySQL ────────────────────────────────────────────────────
# 同梱 MariaDB を使わずに外部 DB に接続する場合:
# 1. docker-compose.yml 起動コマンドから --profile infra を外す
# 2. 以下のコメントを外して接続情報を設定する
#
# DB_HOST=your-mariadb-host.example.com
# DB_PORT=3306
# DB_NAME=mailshield
# DB_USER=mailshield
# DB_PASSWORD=your-password

# ─── 外部 RabbitMQ ──────────────────────────────────────────────────────────
# 同梱 RabbitMQ を使わずに外部 RabbitMQ に接続する場合:
#
# RABBITMQ_HOST=your-rabbitmq-host.example.com
# RABBITMQ_PORT=5672
# RABBITMQ_USER=mailshield
# RABBITMQ_PASSWORD=your-password

# ─── 外部 S3（AWS / GCS / Cloudflare R2 等）────────────────────────────────
# 同梱 MinIO を使わずに外部 S3 に接続する場合:
# 1. docker-compose.yml 起動コマンドから --profile infra を外す（MinIO コンテナ不要）
# 2. 以下のコメントを外して接続情報を設定する
# 3. config/mailshield.yaml と config/api-server.yaml の
#    storage.public_endpoint をブラウザからアクセス可能な S3 エンドポイントに変更する
#
# MINIO_ENDPOINT=s3.amazonaws.com          # AWS S3
# MINIO_ENDPOINT=storage.googleapis.com   # Google Cloud Storage
# MINIO_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
# MINIO_SECRET_KEY=your-secret-key
# MINIO_USE_SSL=true

# ─── 外部 Redis ──────────────────────────────────────────────────────────────
# 同梱 Redis を使わずに外部 Redis に接続する場合:
#
# REDIS_HOST=your-redis-host.example.com
# REDIS_PORT=6379


# =============================================================================
# ▼▼▼ YAML ファイルで設定が必要な項目（本番運用前に必ず確認）▼▼▼
# =============================================================================
#
# 以下の設定は環境変数では制御できません。
# 対応する YAML ファイルを直接編集してください。
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ config/mailshield.yaml （smtp-gateway 設定）                              │
# ├──────────────────────────────────────────────────────────────────────────┤
# │ server.trusted_sources          接続を許可する MTA の IP / ホスト名       │
# │ server.reinject_host/port       処理後メールを渡す先の Postfix アドレス   │
# │ notification.smtp_host/port     隔離通知メールを送る SMTP サーバー         │
# │ notification.from_address       通知メールの送信元アドレス                 │
# │ quarantine_notification.ui_base_url  通知メール内の Web UI リンクの URL   │
# │ routes[].match.to               受信ドメインの正規表現（例: @example\.com$）│
# │ routes[].policy.*               配送先 MTA・ポリシー設定                  │
# └──────────────────────────────────────────────────────────────────────────┘
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │ config/api-server.yaml （api-server / Web UI 設定）                      │
# ├──────────────────────────────────────────────────────────────────────────┤
# │ server.frontend_url             Web UI の公開 URL（CORS オリジン）        │
# │ notification.smtp_host/port     通知メールを送る SMTP サーバー             │
# │ notification.reinject_host/port 隔離解放後の再インジェクト先 Postfix       │
# │ auth.providers.oidc.issuer      OIDC プロバイダーの issuer URL            │
# │ auth.providers.oidc.client_id   OIDC クライアント ID                      │
# │ auth.providers.oidc.redirect_uri  OIDC コールバック URL                   │
# │ storage.public_endpoint         ブラウザから MinIO/S3 にアクセスする URL  │
# └──────────────────────────────────────────────────────────────────────────┘
#
# =============================================================================
