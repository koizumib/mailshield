# MailShield OSS — 環境変数設定例
# =============================================================================
#
#   cp .env.example .env  してから以下の手順で編集してください。
#
#   【設定の2本柱】
#   ① このファイル（.env）  → パスワード・接続先などのインフラ設定
#   ② config/*.yaml        → ドメイン・ルーティング・ポリシーなどのロジック設定
#
#   .env だけ直しても動きません。config/mailshield.yaml も必ず編集してください。
#   何を変えるかは下部の「YAML で変更が必要な項目」セクションを参照してください。
#
# =============================================================================


# =============================================================================
# ▼ STEP 1: パスワード類（必ず変更すること）
# =============================================================================

# MariaDB root パスワード（コンテナ初回起動時のみ使われる）
MARIADB_ROOT_PASSWORD=CHANGE_ME_root_password

# アプリケーション用 DB パスワード
DB_PASSWORD=CHANGE_ME_db_password

# MinIO / S3 認証情報（MinIO をそのまま使う場合は任意の文字列でよい・8文字以上）
MINIO_ACCESS_KEY=CHANGE_ME_access_key
MINIO_SECRET_KEY=CHANGE_ME_secret_key

# RabbitMQ パスワード（queue プロファイルを使う場合）
RABBITMQ_PASSWORD=CHANGE_ME_rabbitmq_password
# RabbitMQ Erlang クッキー（root で Docker を実行するホストでクッキーファイルの
# パーミッションエラーが発生する場合に設定する。任意の文字列でよい）
# RABBITMQ_ERLANG_COOKIE=mailshield-erlang-cookie

# 通知メールの SMTP 認証パスワード（社内 SMTP リレーが認証を要求する場合のみ）
NOTIFICATION_AUTH_PASS=

# OIDC クライアントシークレット（config/api-server.yaml で oidc.enabled: true にする場合のみ）
OIDC_CLIENT_SECRET=


# =============================================================================
# ▼ STEP 2: 自前 MTA との接続設定（必ず変更すること）
# =============================================================================

# smtp-gateway が処理完了後にメールを戻す先の MTA とポート
# 自前 Postfix の content_filter なしのポート（通常は 10025）を指定する
MAILSHIELD_REINJECT_HOST=your-mta-host
MAILSHIELD_REINJECT_PORT=10025

# 隔離通知・OTP メールを送る SMTP リレー
# content_filter と別のポートを使うこと（ループ防止）
MAILSHIELD_NOTIFICATION_SMTP_HOST=your-smtp-relay
MAILSHIELD_NOTIFICATION_SMTP_PORT=25


# =============================================================================
# ▼ 通常は変更不要（同梱インフラをそのまま使う場合のデフォルト値）
# =============================================================================

# MariaDB 接続先（同梱 MariaDB を使う場合はデフォルトのまま）
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=mailshield
DB_USER=mailshield

# MinIO 接続先（storage プロファイルの MinIO を使う場合はデフォルトのまま）
MINIO_ENDPOINT=minio:9000
MINIO_USE_SSL=false

# RabbitMQ 接続先（queue プロファイルの RabbitMQ を使う場合はデフォルトのまま）
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=mailshield

# Redis 接続先（api プロファイルの Redis を使う場合はデフォルトのまま）
REDIS_HOST=redis
REDIS_PORT=6379


# =============================================================================
# ▼ 外部サービスへの切り替え（クラウド DB・S3・RabbitMQ 等を使う場合）
# =============================================================================

# 外部 MariaDB を使う場合: 下記を上書きして mariadb コンテナを停止する
# DB_HOST=your-mariadb.example.com
# DB_PORT=3306
# DB_PASSWORD=your-password

# 外部 RabbitMQ を使う場合（queue プロファイル不要になる）
# RABBITMQ_HOST=your-rabbitmq.example.com
# RABBITMQ_PORT=5672
# RABBITMQ_PASSWORD=your-password

# 外部 S3（AWS / GCS / Cloudflare R2 等）を使う場合（storage プロファイル不要になる）
# MINIO_ENDPOINT=s3.amazonaws.com
# MINIO_ACCESS_KEY=AKIAXXXXXXXXXXXXXXXX
# MINIO_SECRET_KEY=your-secret-key
# MINIO_USE_SSL=true

# 外部 Redis を使う場合（api プロファイルの redis コンテナ不要になる）
# REDIS_HOST=your-redis.example.com
# REDIS_PORT=6379


# =============================================================================
# ▼ YAML ファイルで変更が必要な項目（.env では制御できない設定）
# =============================================================================
#
# config/mailshield.yaml を開いて以下の項目を確認・変更してください:
#
#   server.trusted_sources       ← 自前 MTA の IP またはホスト名を追加
#   routes[].match.to            ← 受信するメールドメインの正規表現
#                                   例: "@example\\.com$"
#   routes[].match.from          ← 送信フィルタ対象ドメインの正規表現
#   quarantine_notification.ui_base_url  ← 通知メール内の Web UI リンク
#
# config/api-server.yaml を開いて以下の項目を確認・変更してください:
#
#   server.frontend_url          ← Web UI の公開 URL（CORS オリジン）
#   storage.public_endpoint      ← ブラウザから MinIO/S3 にアクセスする URL
#   （reinject_host/port は mailshield.yaml の reinject 設定から自動継承されるため省略可）
#   approval.base_url            ← 承認通知メール内リンクのベース URL
#
# =============================================================================
